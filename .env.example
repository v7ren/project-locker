# Copy to `.env.local` and set real values. Do not commit secrets.



# Session / JWT signing secret (minimum 16 characters). Example: openssl rand -base64 32

# Required for any sign-in. If you do NOT set the full email block below, this alone enables

# username-only accounts (first user becomes admin).

AUTH_SECRET=



# --- Email OTP sign-in (optional) ---

# If ALL of the following are valid, sign-in uses email OTP for these addresses only:

#   AUTH_SECRET (16+), AUTH_ALLOWED_EMAILS (non-empty), RESEND_API_KEY, RESEND_FROM

# If AUTH_ALLOWED_EMAILS is empty or invalid (or Resend is missing), deployment falls back to

# username-only sign-in whenever AUTH_SECRET is set.



# Comma-, semicolon-, or newline-separated emails allowed to sign in

AUTH_ALLOWED_EMAILS="you@example.com,you2@example.com"



# Resend API key (required when email OTP auth is enabled)

RESEND_API_KEY=



# Resend "From" (verified domain in Resend, or onboarding@resend.dev for account-only testing)

RESEND_FROM="Onboarding <onboarding@resend.dev>"



# --- Username policy (optional; comma-separated, case-insensitive) ---

# Blocked for everyone (self-register and admin "create user" API)

# AUTH_USERNAME_LOCKED=support,billing

# Self-register blocked; admins can create these via Team calendar → "Create username"

# AUTH_USERNAME_ADMIN_ONLY=lead,oncall

# Rate limit username / backup / admin-access login attempts by IP (15 min window, max 48).
# Omit or set to 0 / false / off to disable (default: disabled).

# AUTH_USERNAME_RATE_LIMIT=1



# Must match the browser Origin header exactly (scheme + host, no trailing slash) for `/api/*` CORS

DOMAIN=https://localhost:3000



# OpenRouter (project AI: chat + embeddings). Get a key at https://openrouter.ai/

OPENROUTER_API_KEY=

# Optional overrides (defaults: openai/gpt-4o-mini, openai/text-embedding-3-small)

# OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini

# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional OpenRouter app attribution

# OPENROUTER_SITE_URL=https://localhost:3000

# OPENROUTER_APP_TITLE=Project dashboard

