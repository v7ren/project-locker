# Copy to `.env.local` and set real values. Do not commit secrets.

# Session / JWT signing secret (minimum 16 characters). Example: openssl rand -base64 32
AUTH_SECRET=

# Comma-, semicolon-, or newline-separated emails allowed to sign in
AUTH_ALLOWED_EMAILS="you@example.com"

# Resend API key (required when email OTP auth is enabled)
RESEND_API_KEY=

# Resend "From" (verified domain in Resend, or onboarding@resend.dev for account-only testing)
RESEND_FROM="Onboarding <onboarding@resend.dev>"

# Must match the browser Origin header exactly (scheme + host, no trailing slash) for `/api/*` CORS
DOMAIN=https://localhost:3000
